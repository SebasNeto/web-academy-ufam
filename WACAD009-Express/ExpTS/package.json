{
  "name": "express-typescript-exercicios",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "nodemon src/index.ts",
    "build": "tsc",
    "start:prod": "node build/index.js",
    "start:db": "json-server --watch data/db.json --port 3355",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "format": "prettier --write src/",
    "sass": "sass sass/main.scss public/css/main.css --watch",
    "sass:build": "sass sass/main.scss public/css/main.css --no-source-map"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "envalid": "^8.1.1",
    "express": "^5.2.1",
    "express-handlebars": "^7.1.3",
    "handlebars": "^4.7.8",
    "json-server": "^0.17.4",
    "lorem-ipsum": "^2.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.4",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.7.4",
    "sass": "^1.97.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0"
  }
}

