<html lang='pt-BR'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1' />
    <title>{{title}} | Minha Loja Virtual</title>
    <link
      href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css'
      rel='stylesheet'
    />
    <link href='/css/main.css' rel='stylesheet' />
  </head>
  <body>
    <nav class='navbar navbar-expand-lg bg-body-tertiary border-bottom mb-4'>
      <div class='container'>
        <a class='navbar-brand' href='/'>Minha Loja Virtual</a>
        <button
          class='navbar-toggler'
          type='button'
          data-bs-toggle='collapse'
          data-bs-target='#mainNavbar'
          aria-controls='mainNavbar'
          aria-expanded='false'
          aria-label='Abrir navegação'
        >
          <span class='navbar-toggler-icon'></span>
        </button>
        <div class='collapse navbar-collapse' id='mainNavbar'>
          <ul class='navbar-nav me-auto mb-2 mb-lg-0'>
            <li class='nav-item'><a class='nav-link' href='/'>Home</a></li>
            <li class='nav-item'><a class='nav-link' href='/hb1'>HB1</a></li>
            <li class='nav-item'><a class='nav-link' href='/hb2'>HB2</a></li>
            <li class='nav-item'><a class='nav-link' href='/hb3'>HB3</a></li>
            <li class='nav-item'><a class='nav-link' href='/hb4'>HB4</a></li>
            <li class='nav-item'><a
                class='nav-link'
                href='/produto'
              >Produtos</a></li>
          </ul>
          <form class='d-flex' action='/lorem/4' method='get'>
            <button class='btn btn-outline-success' type='submit'>Lorem Ipsum</button>
          </form>
        </div>
      </div>
    </nav>
    <main class='container pb-5'>
      {{{body}}}
    </main>
    <script
      src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js'
    ></script>
  </body>
</html>